# Supabase (auth, database, storage)
# Create project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (payments)
# Get keys at https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# PayPal
# Get client ID at https://developer.paypal.com/dashboard/applications
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Payment API (Supabase Edge Function URL)
# After deploying: supabase functions deploy create-payment-intent
# URL format: https://your-project.supabase.co/functions/v1
VITE_PAYMENT_API_URL=

# Zelle email (shown to users for Zelle payments)
VITE_ZELLE_EMAIL=payments@immiguide.com

# Bank transfer details (shown to users for manual transfer)
VITE_BANK_NAME=
VITE_BANK_ACCOUNT_NAME=
VITE_BANK_ROUTING=
VITE_BANK_ACCOUNT=

# Sentry (error monitoring)
VITE_SENTRY_DSN=

# App
VITE_APP_URL=http://localhost:5173
